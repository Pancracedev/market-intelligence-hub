# Copy this file to .env and adjust if needed. Defaults work out of the box for local dev.

# --- MinIO (data lake) ---
# For the serverless deployment path (see docs/DEPLOY_SERVERLESS.md), point these at a
# Cloudflare R2 bucket instead: MINIO_ENDPOINT=<account_id>.r2.cloudflarestorage.com,
# MINIO_SECURE=true, MINIO_ROOT_USER/PASSWORD = R2 access key id/secret, STORAGE_REGION=auto.
# The client is generic S3 (boto3) so no code change is needed, only these variables.
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin123
MINIO_ENDPOINT=minio:9000
MINIO_SECURE=false
STORAGE_REGION=us-east-1
MINIO_BUCKET_BRONZE=bronze
MINIO_BUCKET_SILVER=silver
MINIO_BUCKET_GOLD=gold

# --- API auth ---
JWT_SECRET_KEY=change-me-in-production

# Origins allowed to call the API from a browser (comma-separated). Must match the URL the
# frontend is actually served from, or the browser blocks every request with a CORS error.
CORS_ORIGINS=http://localhost:3000

# --- Frontend ---
# Base URL the frontend calls to reach the API. Next.js inlines this into the JS bundle at
# BUILD time (not read at container startup) — changing it requires rebuilding the frontend
# image: docker compose build frontend && docker compose up -d frontend
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# Seeds a demo account on API startup - handy for local dev and showcase deployments,
# set to "false" if you don't want a shared/guessable account reachable on a public URL.
SEED_DEMO_USER=true
# Override the seeded demo account's credentials (defaults to demo@example.com / demo12345,
# fine for local dev but change both before sharing a public deployment).
DEMO_USER_EMAIL=demo@example.com
DEMO_USER_PASSWORD=demo12345

# --- App Postgres (metadata: users, watchers, runs) ---
# For the serverless path, point these at a Neon (neon.tech) project instead — its
# connection string maps directly to these variables. sslmode=prefer works for both
# local docker-compose Postgres (no TLS) and Neon (requires TLS) without changing it.
APP_DB_USER=app
APP_DB_PASSWORD=app
APP_DB_NAME=market_intelligence
APP_DB_HOST=app-db
APP_DB_PORT=5432
APP_DB_SSLMODE=prefer

# --- Airflow Postgres (Airflow internal metadata, isolated from app db) ---
AIRFLOW_DB_USER=airflow
AIRFLOW_DB_PASSWORD=airflow
AIRFLOW_DB_NAME=airflow
AIRFLOW_DB_HOST=airflow-db
AIRFLOW_DB_PORT=5432

# --- Airflow ---
AIRFLOW_UID=50000
AIRFLOW__CORE__FERNET_KEY=
AIRFLOW__WEBSERVER__SECRET_KEY=change-me-in-production

# --- Email alerts (price drop / stock out / promo) ---
# Leave SMTP_HOST empty to disable email alerts (they'll be skipped, not error out).
# Any real SMTP relay works (provider transactional API, self-hosted relay, etc.).
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_USE_TLS=true

# --- Weekly AI digest ---
# Provider priority: Groq (free tier, no billing required - https://console.groq.com) is
# tried first, then Anthropic if configured, then a plain templated summary with no LLM.
GROQ_API_KEY=
GROQ_DIGEST_MODEL=llama-3.3-70b-versatile
ANTHROPIC_API_KEY=
ANTHROPIC_DIGEST_MODEL=claude-haiku-4-5-20251001
