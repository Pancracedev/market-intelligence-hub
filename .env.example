# Copy this file to .env and adjust if needed. Defaults work out of the box for local dev.

# --- MinIO (data lake) ---
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin123
MINIO_ENDPOINT=minio:9000
MINIO_BUCKET_BRONZE=bronze
MINIO_BUCKET_SILVER=silver
MINIO_BUCKET_GOLD=gold

# --- API auth ---
JWT_SECRET_KEY=change-me-in-production

# Origins allowed to call the API from a browser (comma-separated). Must match the URL the
# frontend is actually served from, or the browser blocks every request with a CORS error.
CORS_ORIGINS=http://localhost:3000

# Seeds demo@example.com / demo12345 on API startup - local/demo only, set to "false" in prod.
SEED_DEMO_USER=true

# --- App Postgres (metadata: users, watchers, runs) ---
APP_DB_USER=app
APP_DB_PASSWORD=app
APP_DB_NAME=market_intelligence
APP_DB_HOST=app-db
APP_DB_PORT=5432

# --- Airflow Postgres (Airflow internal metadata, isolated from app db) ---
AIRFLOW_DB_USER=airflow
AIRFLOW_DB_PASSWORD=airflow
AIRFLOW_DB_NAME=airflow
AIRFLOW_DB_HOST=airflow-db
AIRFLOW_DB_PORT=5432

# --- Airflow ---
AIRFLOW_UID=50000
AIRFLOW__CORE__FERNET_KEY=
AIRFLOW__WEBSERVER__SECRET_KEY=change-me-in-production

# --- Email alerts (price drop / stock out / promo) ---
# Leave SMTP_HOST empty to disable email alerts (they'll be skipped, not error out).
# Any real SMTP relay works (provider transactional API, self-hosted relay, etc.).
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_USE_TLS=true

# --- Weekly AI digest ---
# Provider priority: Groq (free tier, no billing required - https://console.groq.com) is
# tried first, then Anthropic if configured, then a plain templated summary with no LLM.
GROQ_API_KEY=
GROQ_DIGEST_MODEL=llama-3.3-70b-versatile
ANTHROPIC_API_KEY=
ANTHROPIC_DIGEST_MODEL=claude-haiku-4-5-20251001
